{
  "name": "pareta",
  "version": "1.4.0",
  "description": "TypeScript/JavaScript client for Pareta — chat against model \"auto\", benchmark it on your own data, and watch the savings.",
  "license": "Apache-2.0",
  "author": "Pareta",
  "homepage": "https://docs.pareta.ai",
  "repository": { "type": "git", "url": "git+https://github.com/Pareta-AI/pareta-js.git" },
  "bugs": { "url": "https://github.com/Pareta-AI/pareta-js/issues" },
  "keywords": ["pareta", "llm", "inference", "openai", "evals", "open-weights"],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "LICENSE", "README.md"],
  "sideEffects": false,
  "engines": { "node": ">=18" },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
